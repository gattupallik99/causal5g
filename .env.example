# Free5GC
FREE5GC_VERSION=v3.4.2
NETWORK_NAME=causal5g-net

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=5s

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=causal5g

# Loki
LOKI_PORT=3100

# Jaeger
JAEGER_PORT=16686

# Kafka
KAFKA_PORT=9092

# API
API_PORT=8000
API_HOST=0.0.0.0

# Causal Engine
GRANGER_MAX_LAG=10
ANOMALY_THRESHOLD=3.0
GRAPH_WINDOW_SECONDS=60
